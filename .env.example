# Kalshi (prod by default — v1 is read-only, so prod gives real market prices)
KALSHI_ACCESS_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=./secrets/kalshi_private_key.pem
KALSHI_ENV=prod

# OpenWeb Ninja News (direct API — optional; injury/lineup headlines)
# Auth is a single X-API-Key header. Get the key at https://www.openwebninja.com/
OPENWEB_NINJA_API_KEY=
# Base URL override (leave blank to use the default below)
OPENWEB_NINJA_NEWS_HOST=https://api.openwebninja.com

# The Odds API (free tier ~500 req/mo)
THE_ODDS_API_KEY=

# balldontlie (free)
BALLDONTLIE_API_KEY=

# LLM provider (default: Anthropic Claude Opus 4.8 — latest)
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Optional config overrides
#SPORTAGENT_LLM_PROVIDER=anthropic
#SPORTAGENT_DEEP_THINK_LLM=claude-opus-4.8
#SPORTAGENT_QUICK_THINK_LLM=claude-haiku-4.5
#SPORTAGENT_MAX_DEBATE_ROUNDS=1
#SPORTAGENT_MAX_RISK_ROUNDS=1
#SPORTAGENT_KALSHI_ENV=demo
#SPORTAGENT_NO_TRADE_BAND=0.03
#SPORTAGENT_KELLY_CAP=0.25
#SPORTAGENT_TEMPERATURE=